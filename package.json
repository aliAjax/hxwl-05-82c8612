{
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5105",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5105",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui",
    "test:smoke:debug": "playwright test --debug",
    "test:all": "npm run typecheck && npm run build && npm run test:unit && npm run test:smoke",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.9"
  }
}
